{
  "version": "5.0",
  "metrics": [
    {
      "metric_id": "dashboard.epoch_id",
      "display_name_en": "Current Epoch",
      "display_name_cs": "Aktuální Epocha",
      "definition_cs": "ID běžící trénovací epochy",
      "category": "dashboard",
      "unit": "string",
      "value_type": "text",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "epoch_id",
      "update_trigger": "epoch_change",
      "freshness_target_s": 60,
      "android_tab": "Dashboard",
      "visibility": "public",
      "read_cost_note": "1 read per update (rare)"
    },
    {
      "metric_id": "dashboard.open_positions_count",
      "display_name_en": "Open Positions",
      "display_name_cs": "Otevřené Pozice",
      "definition_cs": "Počet současně otevřených pozic",
      "category": "dashboard",
      "unit": "count",
      "value_type": "number",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "open_positions_count",
      "update_trigger": "position_change",
      "freshness_target_s": 1,
      "android_tab": "Dashboard",
      "visibility": "public",
      "read_cost_note": "1 read per second = 86,400 reads/day"
    },
    {
      "metric_id": "dashboard.open_notional_usd",
      "display_name_en": "Open Notional",
      "display_name_cs": "Otevřená Notionální Hodnota",
      "definition_cs": "Celková USD hodnota otevřených pozic",
      "category": "dashboard",
      "unit": "USD",
      "value_type": "currency",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "open_notional_usd",
      "update_trigger": "price_or_position_change",
      "freshness_target_s": 1,
      "android_tab": "Dashboard",
      "visibility": "public",
      "read_cost_note": "1 read per second"
    },
    {
      "metric_id": "dashboard.open_unrealized_pnl_usd",
      "display_name_en": "Unrealized P&L",
      "display_name_cs": "Nerealizovaný Zisk/Ztráta",
      "definition_cs": "Aktuální nerealizovaný P&L across all open positions",
      "category": "dashboard",
      "unit": "USD",
      "value_type": "currency",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "open_unrealized_pnl_usd",
      "update_trigger": "price_change",
      "freshness_target_s": 1,
      "android_tab": "Dashboard",
      "visibility": "public",
      "read_cost_note": "Calculated from local book, 0 Firebase reads"
    },
    {
      "metric_id": "daily.trades_closed",
      "display_name_en": "Closes Today",
      "display_name_cs": "Zavření Dnes",
      "definition_cs": "Počet uzavřených obchodů dnes",
      "category": "daily_statistics",
      "unit": "count",
      "value_type": "number",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "trades_closed_today",
      "update_trigger": "trade_close",
      "freshness_target_s": 60,
      "android_tab": "Dashboard",
      "visibility": "public",
      "read_cost_note": "1 read per update"
    },
    {
      "metric_id": "daily.win_rate_pct",
      "display_name_en": "Win Rate",
      "display_name_cs": "Procento Vítězství",
      "definition_cs": "(wins / total) * 100",
      "category": "daily_statistics",
      "unit": "percent",
      "value_type": "number",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "win_rate",
      "update_trigger": "trade_close",
      "freshness_target_s": 60,
      "android_tab": "Dashboard",
      "visibility": "public",
      "read_cost_note": "Calculated, 0 reads"
    },
    {
      "metric_id": "daily.net_pnl_usd",
      "display_name_en": "Daily P&L",
      "display_name_cs": "Denní Zisk/Ztráta",
      "definition_cs": "Čistý P&L po všech poplatcích dnes",
      "category": "daily_statistics",
      "unit": "USD",
      "value_type": "currency",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "net_pnl_usd",
      "update_trigger": "trade_close",
      "freshness_target_s": 60,
      "android_tab": "Dashboard",
      "visibility": "public",
      "read_cost_note": "1 read per update"
    },
    {
      "metric_id": "trade.last_trade_id",
      "display_name_en": "Last Trade ID",
      "display_name_cs": "ID Poslední Pozice",
      "definition_cs": "ID poslední uzavřené pozice",
      "category": "trading_activity",
      "unit": "string",
      "value_type": "text",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "last_closed_trade.trade_id",
      "update_trigger": "trade_close",
      "freshness_target_s": 1,
      "android_tab": "Trading Activity",
      "visibility": "public",
      "read_cost_note": "0 reads (cached locally)"
    },
    {
      "metric_id": "trade.last_pnl_pct",
      "display_name_en": "Last Trade P&L %",
      "display_name_cs": "P&L Poslední Pozice %",
      "definition_cs": "P&L jako % vstupní notionální hodnoty",
      "category": "trading_activity",
      "unit": "percent",
      "value_type": "number",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "last_closed_trade.net_pnl_pct",
      "update_trigger": "trade_close",
      "freshness_target_s": 1,
      "android_tab": "Trading Activity",
      "visibility": "public",
      "read_cost_note": "0 reads (cached)"
    },
    {
      "metric_id": "strategy.{id}.net_expectancy_bps",
      "display_name_en": "Expectancy",
      "display_name_cs": "Očekávání",
      "definition_cs": "Čistá hodnota v basis points",
      "category": "strategy_performance",
      "unit": "bps",
      "value_type": "number",
      "firebase_document_path": "v5_metrics/strategy_{id}_expectancy",
      "firebase_field_path": "value",
      "update_trigger": "trade_close",
      "freshness_target_s": 300,
      "android_tab": "Strategy",
      "visibility": "public",
      "read_cost_note": "Calculated, 0 reads"
    },
    {
      "metric_id": "strategy.{id}.profit_factor",
      "display_name_en": "Profit Factor",
      "display_name_cs": "Profit Faktor",
      "definition_cs": "wins / losses ratio",
      "category": "strategy_performance",
      "unit": "ratio",
      "value_type": "number",
      "firebase_document_path": "v5_metrics/strategy_{id}_pf",
      "firebase_field_path": "value",
      "update_trigger": "trade_close",
      "freshness_target_s": 300,
      "android_tab": "Strategy",
      "visibility": "public",
      "read_cost_note": "Calculated, 0 reads"
    },
    {
      "metric_id": "quota.state",
      "display_name_en": "Quota State",
      "display_name_cs": "Stav Kvóty",
      "definition_cs": "NORMAL/WARNING/DEGRADED/CRITICAL/HARD_STOP",
      "category": "firebase_quota",
      "unit": "string",
      "value_type": "enum",
      "firebase_document_path": "v5_quota/{quota_date_pt}",
      "firebase_field_path": "state",
      "update_trigger": "quota_change",
      "freshness_target_s": 60,
      "android_tab": "Health",
      "visibility": "public",
      "read_cost_note": "1 read per update"
    },
    {
      "metric_id": "quota.daily_reads_remaining",
      "display_name_en": "Reads Remaining",
      "display_name_cs": "Zbývajících Čtení",
      "definition_cs": "Zbývá čtení dnes (z 50,000 denně)",
      "category": "firebase_quota",
      "unit": "count",
      "value_type": "number",
      "firebase_document_path": "v5_quota/{quota_date_pt}",
      "firebase_field_path": "reads_remaining",
      "update_trigger": "quota_check",
      "freshness_target_s": 60,
      "android_tab": "Health",
      "visibility": "public",
      "read_cost_note": "1 read per minute check"
    },
    {
      "metric_id": "health.feed_connected",
      "display_name_en": "Feed Status",
      "display_name_cs": "Stav Zdroje Dat",
      "definition_cs": "true/false",
      "category": "feed_health",
      "unit": "bool",
      "value_type": "flag",
      "firebase_document_path": "v5_dashboard/current",
      "firebase_field_path": "feed_connected",
      "update_trigger": "feed_change",
      "freshness_target_s": 5,
      "android_tab": "Health",
      "visibility": "public",
      "read_cost_note": "0 reads (local tracking)"
    },
    {
      "metric_id": "readiness.state",
      "display_name_en": "Readiness State",
      "display_name_cs": "Stav Připravenosti",
      "definition_cs": "10-state enum (NOT_READY → REAL_REVIEW_READY)",
      "category": "real_readiness",
      "unit": "string",
      "value_type": "enum",
      "firebase_document_path": "v5_readiness/current",
      "firebase_field_path": "state",
      "update_trigger": "learning_update",
      "freshness_target_s": 300,
      "android_tab": "Readiness",
      "visibility": "public",
      "read_cost_note": "1 read per evaluation"
    },
    {
      "metric_id": "readiness.state_label_cs",
      "display_name_en": "Status (Czech)",
      "display_name_cs": "Stav (Čeština)",
      "definition_cs": "Human-readable Czech status message",
      "category": "real_readiness",
      "unit": "string",
      "value_type": "text",
      "firebase_document_path": "v5_readiness/current",
      "firebase_field_path": "state_label_cs",
      "update_trigger": "learning_update",
      "freshness_target_s": 300,
      "android_tab": "Readiness",
      "visibility": "public",
      "read_cost_note": "0 reads (computed)"
    },
    {
      "metric_id": "readiness.eligible_closes",
      "display_name_en": "Eligible Closes",
      "display_name_cs": "Kvalifikované Zavření",
      "definition_cs": "current / required (e.g., \"250/300\")",
      "category": "real_readiness",
      "unit": "count",
      "value_type": "text",
      "firebase_document_path": "v5_readiness/current",
      "firebase_field_path": "eligible_closes",
      "update_trigger": "learning_update",
      "freshness_target_s": 300,
      "android_tab": "Readiness",
      "visibility": "public",
      "read_cost_note": "0 reads (computed)"
    },
    {
      "metric_id": "control.paper_only",
      "display_name_en": "Paper Mode Only",
      "display_name_cs": "Režim Pouze Papír",
      "definition_cs": "true (always)",
      "category": "control_safety",
      "unit": "bool",
      "value_type": "flag",
      "firebase_document_path": "v5_control/active",
      "firebase_field_path": "paper_only",
      "update_trigger": "control_change",
      "freshness_target_s": 3600,
      "android_tab": "Readiness",
      "visibility": "public",
      "read_cost_note": "0 reads (hardcoded)"
    },
    {
      "metric_id": "control.real_orders_allowed",
      "display_name_en": "Real Orders Allowed",
      "display_name_cs": "REAL Obchody Povoleny",
      "definition_cs": "false (always)",
      "category": "control_safety",
      "unit": "bool",
      "value_type": "flag",
      "firebase_document_path": "v5_control/active",
      "firebase_field_path": "real_orders_allowed",
      "update_trigger": "control_change",
      "freshness_target_s": 3600,
      "android_tab": "Readiness",
      "visibility": "public",
      "read_cost_note": "0 reads (hardcoded)"
    }
  ],
  "android_tabs": [
    {
      "tab_id": "dashboard",
      "tab_label_en": "Dashboard",
      "tab_label_cs": "Ovládací Panel",
      "metrics": [
        "dashboard.epoch_id",
        "dashboard.open_positions_count",
        "dashboard.open_notional_usd",
        "daily.trades_closed",
        "daily.win_rate_pct",
        "daily.net_pnl_usd"
      ]
    },
    {
      "tab_id": "trading",
      "tab_label_en": "Trading Activity",
      "tab_label_cs": "Obchodní Aktivita",
      "metrics": [
        "trade.last_trade_id",
        "trade.last_pnl_pct"
      ]
    },
    {
      "tab_id": "strategy",
      "tab_label_en": "Strategy",
      "tab_label_cs": "Strategie",
      "metrics": [
        "strategy.{id}.net_expectancy_bps",
        "strategy.{id}.profit_factor"
      ]
    },
    {
      "tab_id": "health",
      "tab_label_en": "Health & Quota",
      "tab_label_cs": "Zdraví & Kvóta",
      "metrics": [
        "quota.state",
        "quota.daily_reads_remaining",
        "health.feed_connected"
      ]
    },
    {
      "tab_id": "readiness",
      "tab_label_en": "REAL Readiness",
      "tab_label_cs": "Připravenost REAL",
      "metrics": [
        "readiness.state",
        "readiness.state_label_cs",
        "readiness.eligible_closes",
        "control.paper_only",
        "control.real_orders_allowed"
      ]
    }
  ]
}
