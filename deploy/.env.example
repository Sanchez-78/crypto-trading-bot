# CryptoMaster Environment Variables
# Copy to /opt/cryptomaster/.env on the server and fill in the values

# Binance API (required for live trading)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# Firebase (required for state persistence)
# Base64-encode your firebase_key.json:  base64 -w 0 firebase_key.json
FIREBASE_KEY_BASE64=your_base64_encoded_firebase_key_here

# Redis — local on the server, no change needed
REDIS_URL=redis://localhost:6379/0

# Optional: isolate Firebase collections (e.g. "prod_" or "hetzner_")
COLLECTION_PREFIX=
