# PHASE 2: REAL TRADING CONFIGURATION
# Last updated: 2026-07-01
# Status: PRODUCTION DEPLOYMENT WITH SAFETY GATES

# ═══════════════════════════════════════════════════════════════
# TRADING MODE
# ═══════════════════════════════════════════════════════════════
TRADING_MODE=real_live
# Options: paper_live (paper trading), real_live (real money)
# ⚠️ CRITICAL: Set to 'real_live' only after full Phase 1 + Phase 2 validation

# ═══════════════════════════════════════════════════════════════
# ACCOUNT & RISK MANAGEMENT
# ═══════════════════════════════════════════════════════════════
ACCOUNT_BALANCE_USD=5000
# Starting account balance for position sizing calculations

MAX_DAILY_LOSS_PCT=0.02
# Maximum daily loss as % of account (2% = $100 on $5000 account)

KELLY_SAFETY_FACTOR=0.25
# Conservative Kelly fraction (0.25 = use 25% of Kelly sizing)

MIN_POSITION_SIZE_USD=10
# Minimum position size per trade

MAX_POSITION_SIZE_USD=100
# Absolute maximum position size (safety cap)

# ═══════════════════════════════════════════════════════════════
# ENTRY & EXIT PARAMETERS
# ═══════════════════════════════════════════════════════════════
# Use conservative proven values (Cycle 52 baseline: WR 55.13%)
# Reduced from 50/40 bps which caused timeout regression
PAPER_TP_ZONE_BPS=35
PAPER_SL_ZONE_BPS=40
# Will be overridden by learned regime_tp_strategy when blend > 0%
# Current: learning blend ~10%, so 90% uses these static values

# ═══════════════════════════════════════════════════════════════
# MONITORING & ALERTS
# ═══════════════════════════════════════════════════════════════
DRAWDOWN_ALERT_PCT=0.05
# Alert if drawdown exceeds 5% during session

CIRCUIT_BREAKER_ENABLED=true
# Enable automatic circuit breaker on daily loss limit

MANUAL_OVERRIDE_ENABLED=true
# Enable manual kill switch

# ═══════════════════════════════════════════════════════════════
# SYMBOLS TO TRADE
# ═══════════════════════════════════════════════════════════════
ACTIVE_SYMBOLS=BTCUSDT,ETHUSDT,ADAUSDT,XRPUSDT,BNBUSDT
# Limit to 5 symbols for monitoring simplicity

# ═══════════════════════════════════════════════════════════════
# SAFETY FEATURES
# ═══════════════════════════════════════════════════════════════
EMERGENCY_MODE_ON_REGRESSION=true
# Trigger emergency mode (auto-revert to paper) if WR drops below 40% in 1h

EMERGENCY_MODE_ON_QUOTA=true
# Trigger emergency mode if Firebase quota > 80%

MANUAL_KILL_SWITCH_HOTKEY=ctrl+shift+k
# Manual kill switch (if implemented with keyboard listener)

# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT METADATA
# ═══════════════════════════════════════════════════════════════
DEPLOYMENT_DATE=2026-07-01
DEPLOYMENT_PHASE=2_real_trading_safety
DEPLOYMENT_VERSION=v10.52_real_trading
AUTHORIZED_BY=autonomous_system
SAFETY_FRAMEWORK=active
CIRCUIT_BREAKER_STATUS=active
POSITION_SIZING=kelly_with_0.25_safety_factor
LEARNING_BLEND=10%_ramping_to_100%
