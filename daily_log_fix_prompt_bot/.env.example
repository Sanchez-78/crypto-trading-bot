# Daily Log Fix Prompt Bot Configuration

# Hetzner SSH Access
HETZNER_HOST=1.2.3.4
HETZNER_PORT=22
HETZNER_USER=root
SSH_KEY_PATH=~/.ssh/id_ed25519

# CryptoMaster Service
SERVICE_NAME=cryptomaster
LOG_LOOKBACK_HOURS=24
PROJECT_ROOT=/opt/CryptoMaster_srv
REMOTE_LOG_GLOB=/var/log/cryptomaster/*.log

# Log Fetching
USE_JOURNALCTL=true
MAX_LOG_LINES=50000
SANITIZE_SECRETS=true

# Local Output
LOCAL_REPORT_DIR=reports

# Features (disabled by default for safety)
ENABLE_REMOTE_WRITE=false
ENABLE_AUTO_FIX=false

# LLM Integration (optional)
LLM_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
