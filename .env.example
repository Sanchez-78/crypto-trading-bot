# CryptoMaster V10.13u+20 — Paper Training Mode + Live Readiness Configuration
# Copy this file to .env and adjust for your deployment

# ════════════════════════════════════════════════════════════════════════════
# TRADING MODE (CRITICAL)
# ════════════════════════════════════════════════════════════════════════════
# Options: paper_live, replay_train, live_real
# Default: paper_live (safe, no real orders)
TRADING_MODE=paper_live

# ════════════════════════════════════════════════════════════════════════════
# LIVE ORDER PROTECTION (CRITICAL)
# ════════════════════════════════════════════════════════════════════════════
# Enable real orders to Binance exchange
# Default: false (no real orders placed)
ENABLE_REAL_ORDERS=false

# Explicit confirmation required to enable live trading
# MUST be true AND TRADING_MODE=live_real AND ENABLE_REAL_ORDERS=true
# Default: false (requires manual override)
LIVE_TRADING_CONFIRMED=false

# ════════════════════════════════════════════════════════════════════════════
# PAPER TRADING & EXPLORATION
# ════════════════════════════════════════════════════════════════════════════
# Enable controlled paper exploration (weak rejects, negative EV probes)
# Only applies in paper_live and replay_train modes
# Default: true (learning through exploration)
PAPER_EXPLORATION_ENABLED=true

# Paper exploration profile: conservative, balanced, aggressive_training
# Default: balanced (moderate exploration, learning-friendly)
PAPER_EXPLORATION_PROFILE=balanced

# ════════════════════════════════════════════════════════════════════════════
# FIREBASE & DATA
# ════════════════════════════════════════════════════════════════════════════
# Firebase project ID
FIREBASE_PROJECT_ID=cryptomaster-live-v10

# Firebase database URL (default Firestore)
FIREBASE_DATABASE_URL=https://cryptomaster-live-v10.firebaseio.com

# Write closed trades to Firebase (paper mode)
# Default: true (learning updates enabled)
FIREBASE_TRADES_WRITE=true

# ════════════════════════════════════════════════════════════════════════════
# EXCHANGE SETTINGS
# ════════════════════════════════════════════════════════════════════════════
# Binance API key (required for real orders)
BINANCE_API_KEY=

# Binance API secret (required for real orders)
BINANCE_API_SECRET=

# Testnet mode (for live_real testing without real money)
BINANCE_USE_TESTNET=false

# ════════════════════════════════════════════════════════════════════════════
# SAFETY & LIMITS
# ════════════════════════════════════════════════════════════════════════════
# Maximum position value in USD (per trade)
MAX_POSITION_USD=500

# Maximum daily loss in USD (kill switch)
MAX_DAILY_LOSS_USD=1000

# Maximum open positions
MAX_OPEN_POSITIONS=5

# ════════════════════════════════════════════════════════════════════════════
# LOGGING & DIAGNOSTICS
# ════════════════════════════════════════════════════════════════════════════
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable verbose diagnostics
VERBOSE_LOGGING=false

# ════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT
# ════════════════════════════════════════════════════════════════════════════
# Environment: development, staging, production
ENVIRONMENT=development

# Enable dashboard/metrics export
ENABLE_DASHBOARD=true

# ════════════════════════════════════════════════════════════════════════════
# IMPORTANT NOTES
# ════════════════════════════════════════════════════════════════════════════
# ✅ SAFE DEFAULTS: This configuration places NO real orders by default
# ✅ PAPER MODE: All trades simulated with real live/historical prices
# ✅ EXPLORATION: Controlled learning through weak-reject overrides
#
# ⚠️  TO ENABLE LIVE TRADING:
#    1. Set TRADING_MODE=live_real
#    2. Set ENABLE_REAL_ORDERS=true
#    3. Set LIVE_TRADING_CONFIRMED=true
#    4. Set PAPER_EXPLORATION_ENABLED=false
#    5. Provide BINANCE_API_KEY and BINANCE_API_SECRET
#    6. Review promotion_report for readiness
#    7. Manually start with VERY SMALL position/daily loss limits
#
# ✗ DO NOT use live trading until readiness conditions are met
# ✗ DO NOT enable all three guards simultaneously without review
